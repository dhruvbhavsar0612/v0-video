# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate-a-random-secret-here

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:admin@localhost:5434/reelforge

# ─── AWS S3 ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=reelforge-assets

# Optional: Custom S3 endpoint (for MinIO, LocalStack, R2, etc.)
# S3_ENDPOINT=http://localhost:9000

# Optional: CDN URL for serving assets
# CDN_URL=https://cdn.yourdomain.com

# ─── AI/LLM API Keys ────────────────────────────────────────────────
# At least one AI provider key is required for the agent to work.
# Users can also configure keys per-provider in the Settings sidebar.
# Env vars act as fallback when no user-level key is configured.

# Anthropic (required for default agent — Claude Sonnet 4)
ANTHROPIC_API_KEY=your-anthropic-key

# OpenAI (optional — for GPT-4o, o3 models)
# OPENAI_API_KEY=your-openai-key

# Google Gemini (required for video review tool)
GEMINI_API_KEY=your-gemini-key

# Legacy alias for Gemini (some SDKs use this)
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key

# ─── Stock Media APIs ───────────────────────────────────────────────
# PEXELS_API_KEY=your-pexels-key

# ─── AI Generation APIs ─────────────────────────────────────────────
# FAL_KEY=your-fal-key
# ELEVENLABS_API_KEY=your-elevenlabs-key

# ─── MCP Configuration ──────────────────────────────────────────────
# Path to MCP server config (defaults to ./mcp-servers.json)
# MCP_CONFIG_PATH=./mcp-servers.json
